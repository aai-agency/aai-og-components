{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitReturns": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "~/*": ["./src/*"],
      "@aai-agency/og-components": ["../../packages/og-components/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
