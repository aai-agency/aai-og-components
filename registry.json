{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "@aai/og-components",
  "homepage": "https://github.com/aai-agency/aai-og-components",
  "items": [
    {
      "name": "og-map",
      "type": "registry:component",
      "title": "Asset Map",
      "description": "Interactive map for Oil & Gas assets. Shows wells, pipelines, facilities, and custom asset types on a Mapbox map with clustering, color schemes, drawing tools, overlay uploads, and detail cards.",
      "files": [
        { "path": "components/map/map.tsx", "type": "registry:component" },
        { "path": "components/map/map.types.ts", "type": "registry:component" },
        { "path": "components/map/tooltip.tsx", "type": "registry:component" },
        { "path": "components/map/use-clusters.ts", "type": "registry:component" },
        { "path": "components/map/theme.ts", "type": "registry:component" },
        { "path": "components/map/controls/map-controls.tsx", "type": "registry:component" },
        { "path": "components/map/draw-modes/circle.ts", "type": "registry:component" },
        { "path": "components/map/draw-modes/rectangle.ts", "type": "registry:component" },
        { "path": "components/map/draw-modes/polygon.ts", "type": "registry:component" },
        { "path": "components/map/draw-modes/helpers.ts", "type": "registry:component" },
        { "path": "components/map/draw-modes/types.ts", "type": "registry:component" },
        { "path": "components/map/overlay-manager/overlay-manager.tsx", "type": "registry:component" },
        { "path": "components/map/selection-summary/selection-summary-card.tsx", "type": "registry:component" },
        { "path": "components/map/selection-summary/selection-panel.tsx", "type": "registry:component" },
        { "path": "components/map/selection-summary/filter-chips.tsx", "type": "registry:component" },
        { "path": "components/map/selection-summary/mini-card.tsx", "type": "registry:component" },
        { "path": "components/map/asset-detail/asset-detail-card.tsx", "type": "registry:component" },
        { "path": "types/index.ts", "type": "registry:component" },
        { "path": "schemas/index.ts", "type": "registry:component" },
        { "path": "utils/index.ts", "type": "registry:component" },
        { "path": "utils/overlay-parsers.ts", "type": "registry:component" },
        { "path": "machines/map.machine.ts", "type": "registry:component" }
      ],
      "dependencies": [
        "mapbox-gl",
        "@mapbox/mapbox-gl-draw",
        "@deck.gl/core",
        "@deck.gl/layers",
        "@deck.gl/mapbox",
        "deck.gl",
        "supercluster",
        "@turf/turf",
        "xstate",
        "@xstate/react",
        "zod",
        "jszip",
        "shpjs"
      ],
      "registryDependencies": [],
      "meta": {
        "category": "visualization",
        "aliases": ["well-map", "asset-map", "oil-gas-map", "pipeline-map", "field-map"],
        "requires": "Mapbox access token",
        "peerDependencies": "react >= 18"
      }
    },
    {
      "name": "production-chart",
      "type": "registry:component",
      "title": "Production Chart",
      "description": "Time series chart for oil, gas, and water production data. Dual Y-axis (oil/water left, gas right), clickable legend, hover tooltips, zoom brush, annotations, and forecast overlay. Can be used inside the map detail card or standalone.",
      "files": [
        { "path": "components/map/asset-detail/production-chart.tsx", "type": "registry:component" },
        { "path": "components/map/theme.ts", "type": "registry:component" },
        { "path": "types/index.ts", "type": "registry:component" },
        { "path": "utils/index.ts", "type": "registry:component" }
      ],
      "dependencies": ["uplot"],
      "registryDependencies": [],
      "meta": {
        "category": "visualization",
        "aliases": ["decline-chart", "well-chart", "time-series-chart", "oil-chart"],
        "css": "uplot/dist/uPlot.min.css"
      }
    },
    {
      "name": "asset-detail-card",
      "type": "registry:component",
      "title": "Asset Detail Card",
      "description": "Detail panel that shows when clicking an asset on the map. Displays asset properties, production totals, and custom sections. Includes the production chart when time series data is available.",
      "files": [
        { "path": "components/map/asset-detail/asset-detail-card.tsx", "type": "registry:component" },
        { "path": "components/map/asset-detail/production-chart.tsx", "type": "registry:component" },
        { "path": "components/map/theme.ts", "type": "registry:component" },
        { "path": "types/index.ts", "type": "registry:component" }
      ],
      "dependencies": ["uplot"],
      "registryDependencies": ["production-chart"],
      "meta": {
        "category": "display",
        "aliases": ["well-card", "asset-panel", "detail-panel", "info-card"]
      }
    },
    {
      "name": "overlay-manager",
      "type": "registry:component",
      "title": "Overlay Manager",
      "description": "Upload and manage map overlays. Supports KMZ, KML, GeoJSON, and Shapefile formats. Drag-and-drop upload, style editor (fill color, stroke, opacity), per-feature visibility toggles, and feature property inspection.",
      "files": [
        { "path": "components/map/overlay-manager/overlay-manager.tsx", "type": "registry:component" },
        { "path": "utils/overlay-parsers.ts", "type": "registry:component" },
        { "path": "types/index.ts", "type": "registry:component" }
      ],
      "dependencies": ["jszip", "shpjs"],
      "registryDependencies": [],
      "meta": {
        "category": "data",
        "aliases": ["file-upload", "kmz-upload", "kml-viewer", "shapefile-viewer", "geojson-overlay"],
        "supportedFormats": ["KMZ", "KML", "GeoJSON", "Shapefile"]
      }
    },
    {
      "name": "selection-panel",
      "type": "registry:component",
      "title": "Selection Panel",
      "description": "Multi-select assets by drawing shapes on the map. Shows selected assets in a panel with filter chips, summary cards, and mini cards for quick review.",
      "files": [
        { "path": "components/map/selection-summary/selection-summary-card.tsx", "type": "registry:component" },
        { "path": "components/map/selection-summary/selection-panel.tsx", "type": "registry:component" },
        { "path": "components/map/selection-summary/filter-chips.tsx", "type": "registry:component" },
        { "path": "components/map/selection-summary/mini-card.tsx", "type": "registry:component" },
        { "path": "types/index.ts", "type": "registry:component" }
      ],
      "dependencies": [],
      "registryDependencies": [],
      "meta": {
        "category": "interaction",
        "aliases": ["lasso-select", "multi-select", "asset-filter", "selection-summary"]
      }
    },
    {
      "name": "drawing-tools",
      "type": "registry:component",
      "title": "Drawing Tools",
      "description": "Internal drawing modes used by MapControls. Draw polygons, rectangles, and circles on the map to select assets within an area. Integrates with Mapbox GL Draw. Enable via the controls prop on OGMap.",
      "files": [
        { "path": "components/map/draw-modes/circle.ts", "type": "registry:component" },
        { "path": "components/map/draw-modes/rectangle.ts", "type": "registry:component" },
        { "path": "components/map/draw-modes/polygon.ts", "type": "registry:component" },
        { "path": "components/map/draw-modes/helpers.ts", "type": "registry:component" },
        { "path": "components/map/draw-modes/types.ts", "type": "registry:component" }
      ],
      "dependencies": ["@mapbox/mapbox-gl-draw", "@turf/turf"],
      "registryDependencies": [],
      "meta": {
        "category": "interaction",
        "aliases": ["polygon-draw", "lasso", "area-select", "geo-fence"]
      }
    },
    {
      "name": "local-storage",
      "type": "registry:component",
      "title": "Local Storage",
      "description": "Save assets, overlays, and map views to the browser's localStorage so data survives page refreshes. Drop-in storage backend for OGMap.",
      "files": [
        { "path": "services/localstorage-store.ts", "type": "registry:component" },
        { "path": "services/memory-store.ts", "type": "registry:component" },
        { "path": "types/index.ts", "type": "registry:component" }
      ],
      "dependencies": [],
      "registryDependencies": [],
      "meta": {
        "category": "data",
        "aliases": ["persistence", "save-data", "browser-storage", "offline"]
      }
    },
    {
      "name": "sqlite-storage",
      "type": "registry:component",
      "title": "SQLite Storage",
      "description": "Save assets, overlays, and map views to an in-browser SQLite database. Better for large datasets (10,000+ assets). Uses sql.js (WebAssembly SQLite).",
      "files": [
        { "path": "services/sqlite-store.ts", "type": "registry:component" },
        { "path": "services/create-sqlite-store.ts", "type": "registry:component" },
        { "path": "services/migrate-store.ts", "type": "registry:component" },
        { "path": "types/index.ts", "type": "registry:component" }
      ],
      "dependencies": ["sql.js"],
      "registryDependencies": [],
      "meta": {
        "category": "data",
        "aliases": ["database", "large-dataset", "wasm-sqlite", "offline-db"]
      }
    }
  ]
