{
  "name": "@aai-og/components",
  "version": "0.1.0",
  "description": "Production-grade UI components for oil & gas applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./machines": {
      "types": "./dist/machines/index.d.ts",
      "import": "./dist/machines/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@xstate/react": "^6.1.0",
    "jszip": "^3.10.1",
    "mapbox-gl": "^3.9.4",
    "react-map-gl": "^7.1.8",
    "sql.js": "^1.14.1",
    "supercluster": "^8.0.1",
    "xstate": "^5.28.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/supercluster": "^7.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "keywords": [
    "oil-gas",
    "asset-map",
    "well-map",
    "petroleum",
    "upstream",
    "pipeline",
    "xstate",
    "production-data",
    "react-components",
    "shadcn",
    "kmz",
    "kml",
    "geojson"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aai-agency/aai-components"
  }
}
