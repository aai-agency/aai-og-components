{
  "name": "@aai-agency/og-components",
  "version": "0.1.1",
  "description": "Production-grade O&G React components for AI coding agents — maps, charts, detail cards, and more",
  "author": "Husam @ aai.agency <husam@aai.agency>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./machines": {
      "types": "./dist/machines/index.d.ts",
      "import": "./dist/machines/index.js"
    },
    "./styles.css": "./src/styles.css",
    "./sample-data": {
      "types": "./dist/sample-data/index.d.ts",
      "import": "./dist/sample-data/index.js"
    }
  },
  "files": ["dist", "src/styles.css", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4",
    "mapbox-gl": ">=3"
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mapbox": "^9.2.11",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@turf/turf": "^7.3.4",
    "@xstate/react": "^6.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deck.gl": "^9.2.11",
    "jszip": "^3.10.1",
    "react-virtuoso": "^4.18.4",
    "shpjs": "^6.2.0",
    "sql.js": "^1.14.1",
    "supercluster": "^8.0.1",
    "tailwind-merge": "^3.5.0",
    "uplot": "^1.6.32",
    "xstate": "^5.28.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/jszip": "^3.4.1",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/shpjs": "^3.4.7",
    "@types/supercluster": "^7.1.3",
    "@tailwindcss/vite": "^4.0.14",
    "mapbox-gl": "^3.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.14",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "keywords": [
    "oil-gas",
    "asset-map",
    "well-map",
    "petroleum",
    "upstream",
    "pipeline",
    "xstate",
    "production-data",
    "react-components",
    "shadcn",
    "kmz",
    "kml",
    "geojson"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aai-agency/aai-og-components"
  },
  "homepage": "https://github.com/aai-agency/aai-og-components",
  "bugs": "https://github.com/aai-agency/aai-og-components/issues"
}
